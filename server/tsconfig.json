{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "target": "es2015",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "./node_modules",
    "./node_modules/*",
    "./node_modules/@types/node/index.d.ts"
  ]
}
